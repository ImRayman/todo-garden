{
  "name": "todo-garden",
  "version": "1.0.0",
  "description": "Todo Garden - A garden-themed task manager",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "repository": {
    "type": "git",
