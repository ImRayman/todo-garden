  },
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.todogarden.app",
    "productName": "Todo Garden",
    "mac": {
      "category": "public.app-category.productivity",
